{
  "mcpServers": {
    "sanity": {
      "command": "npx",
      "args": [
        "-y",
        "@sanity/mcp-server@latest"
      ],
      "env": {
        "SANITY_PROJECT_ID": "${NEXT_PUBLIC_SANITY_PROJECT_ID}",
        "SANITY_DATASET": "production",
        "SANITY_API_TOKEN": "${SANITY_API_TOKEN}"
      }
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "env": {
        "DEFAULT_MINIMUM_TOKENS": "10000"
      }
    }
  }
}

// Setup: Copy relevant env values from .env.local when running MCP tools
// Sanity MCP: Allows reading/writing Sanity schemas and documents directly
// Context7: Pulls up-to-date docs for Next.js, Tailwind, Sanity, Pinecone, Framer Motion
