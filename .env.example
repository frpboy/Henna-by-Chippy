# ================================================================
# Henna by Chippy — Environment Variables
# ================================================================
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to git.
# ================================================================

# ----------------------------------------------------------------
# SANITY CMS
# Get from: https://sanity.io/manage → Your Project → API
# ----------------------------------------------------------------
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
# API Token with Editor permissions (for server-side writes)
SANITY_API_TOKEN=your_sanity_api_token_here
# Webhook secret (for ISR revalidation)
SANITY_WEBHOOK_SECRET=your_webhook_secret_here

# ----------------------------------------------------------------
# GOOGLE GEMINI AI
# Get from: https://aistudio.google.com/apikey
# Model used: gemini-2.5-flash (latest stable)
# ----------------------------------------------------------------
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key_here

# ----------------------------------------------------------------
# PINECONE VECTOR DATABASE
# Get from: https://app.pinecone.io
# Index settings: 1536 dimensions, cosine metric
# ----------------------------------------------------------------
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=henna-knowledge-base

# ----------------------------------------------------------------
# BUSINESS CONFIGURATION
# ----------------------------------------------------------------
# WhatsApp number with country code (no + or spaces)
NEXT_PUBLIC_WHATSAPP_NUMBER=917561856754

# Site URL — use your Vercel preview URL during dev (e.g. https://henna-by-chippy.vercel.app)
# Domain not yet decided — update this when a custom domain is registered
# Leave empty locally; Vercel sets VERCEL_URL automatically in production
NEXT_PUBLIC_SITE_URL=https://henna-by-chippy.vercel.app

# ----------------------------------------------------------------
# GOOGLE SEARCH CONSOLE
# Get verification code from: https://search.google.com/search-console
# Add as metadata.verification.google in src/app/layout.tsx
# Also tracks AI Overview citations (GEO) under Performance → AI Overviews
# ----------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_gsc_verification_code_here

# ----------------------------------------------------------------
# ANALYTICS (Optional — set up in Vercel dashboard)
# ----------------------------------------------------------------
# Vercel Analytics is enabled via the @vercel/analytics package
# PostHog for product analytics (optional)
# NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key_here
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ----------------------------------------------------------------
# INSTAGRAM / FACEBOOK (for feed embed + customer post oEmbed)
# Get token from: https://developers.facebook.com/apps
# Requires: Facebook Graph API (Instagram oEmbed is part of Graph API)
# Used for:
#   1. Embedding Chippy's Instagram feed on the homepage
#   2. Fetching oEmbed HTML for customer Instagram posts in reviews/showcase
#      (server-side proxy at /api/oembed — token is never exposed to client)
# ----------------------------------------------------------------
INSTAGRAM_ACCESS_TOKEN=your_long_lived_token_here
NEXT_PUBLIC_INSTAGRAM_HANDLE=hennabyChippy

# ----------------------------------------------------------------
# REVIEW FORM (Optional — if using a form service)
# For post-purchase review collection via Formspree or similar
# ----------------------------------------------------------------
# REVIEW_FORM_ENDPOINT=your_form_endpoint_here
