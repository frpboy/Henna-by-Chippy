# ================================================================
# Henna by Chippy — .gitignore
# ================================================================

# ── Environment & Secrets ──────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem

# ── Next.js ────────────────────────────────────────────────────
.next/
out/
next-env.d.ts

# ── Node ───────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Build & Cache ──────────────────────────────────────────────
.cache/
dist/
build/
*.tsbuildinfo

# ── Sanity ─────────────────────────────────────────────────────
.sanity/
sanity/dist/

# ── OS & Editor ────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/settings.json

# ── Test coverage ──────────────────────────────────────────────
coverage/
.nyc_output/

# ── Vercel ─────────────────────────────────────────────────────
.vercel/

# ── Logs ───────────────────────────────────────────────────────
logs/
*.log

# ── Python (agent scripts) ─────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.agent/.shared/ui-ux-pro-max/scripts/__pycache__/
